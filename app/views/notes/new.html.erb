<% content_for :title, "New note" %>

<div class="flex flex-col items-center lg:w-1/2 md:w-2/3 w-full px-2 h-full gap-2">
  <div class="flex w-full justify-between">
    <%= link_to notes_path,
      class: "p-2 rounded-lg" do %>
      <%= svg_icon "arrow-left", class: "w-6 dark:invert" %>
    <% end %>
  </div>

  <div class="flex-1 w-full"><%= render "form", note: @note %></div>
</div>
